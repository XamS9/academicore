# ── Docker Compose DB credentials ──────────────────────
POSTGRES_USER=academicore
POSTGRES_PASSWORD=academicore_pass
POSTGRES_DB=academicore

# ── Backend (used by Express + Prisma) ─────────────────
# Local dev:  postgresql://USER:PASSWORD@localhost:5432/academicore
# Docker:     postgresql://academicore:academicore_pass@db:5432/academicore
DATABASE_URL="postgresql://academicore:academicore_pass@localhost:5432/academicore"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3000/api
# Optional: true to prefill login with E2E seed users (admin123 / teacher123 / student123, same as demo)
VITE_E2E_PREFILL=false
