// ============================================================
// ACADEMICORE — Prisma Schema
// DB: PostgreSQL | ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserType {
  STUDENT
  TEACHER
  ADMIN
}

enum AcademicStatus {
  PENDING
  ACTIVE
  AT_RISK
  ELIGIBLE_FOR_GRADUATION
  SUSPENDED
  GRADUATED
  WITHDRAWN
}

enum EnrollmentStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum EnrollmentSubjectStatus {
  ENROLLED
  DROPPED
  COMPLETED
  FAILED
}

enum CertificationType {
  DEGREE
  TRANSCRIPT
  COMPLETION
}

enum CertificationStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  REVOKED
  ISSUED
  ENROLLED
  DROPPED
  STATUS_CHANGE
}

enum ContentItemType {
  LINK
  TEXT
  FILE_REF
}

enum NotificationType {
  GRADE_POSTED
  ENROLLMENT_CONFIRMED
  CERTIFICATION_ISSUED
  ANNOUNCEMENT
  PAYMENT_DUE
  PAYMENT_CONFIRMED
  GENERAL
}

enum FeeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

enum AnnouncementAudience {
  ALL
  CAREER
  GROUP
}

enum CalendarEventType {
  HOLIDAY
  EXAM_WEEK
  DEADLINE
  OTHER
}

enum GroupDeliveryMode {
  ON_SITE
  VIRTUAL
  HYBRID
}

enum PeriodStatus {
  OPEN
  GRADING
  CLOSED
}

enum AdmissionDocumentType {
  ID_CARD
  HIGH_SCHOOL_DIPLOMA
  PHOTO
  MEDICAL_CERT
  OTHER
}

enum AdmissionDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// 1. USERS — Supertype
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  userType     UserType  @map("user_type")
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  student         Student?
  teacher         Teacher?
  userRoles       UserRole[]
  gradesGiven     Grade[]             @relation("GradedBy")
  certIssued      Certification[]     @relation("IssuedBy")
  auditLogs       AuditLog[]
  settingsUpdates SystemSettings[]    @relation("SettingsUpdatedBy")
  notifications   Notification[]
  announcements   Announcement[]
  docsReviewed    AdmissionDocument[] @relation("AdmissionDocsReviewed")

  @@map("users")
}

// ─────────────────────────────────────────────
// 2. STUDENTS — Subtype of users
// ─────────────────────────────────────────────

model Student {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @map("user_id") @db.Uuid
  studentCode    String         @unique @map("student_code") @db.VarChar(50)
  careerId       String         @map("career_id") @db.Uuid
  academicStatus AcademicStatus @default(ACTIVE) @map("academic_status")
  enrollmentDate DateTime       @default(now()) @map("enrollment_date") @db.Date
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user               User                @relation(fields: [userId], references: [id])
  career             Career              @relation(fields: [careerId], references: [id])
  enrollments        Enrollment[]
  grades             Grade[]
  academicRecords    AcademicRecord[]
  certifications     Certification[]
  studentFees        StudentFee[]
  submissions        StudentSubmission[]
  admissionDocuments AdmissionDocument[]

  @@map("students")
}

// ─────────────────────────────────────────────
// 3. TEACHERS — Subtype of users
// ─────────────────────────────────────────────

model Teacher {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @unique @map("user_id") @db.Uuid
  employeeCode String    @unique @map("employee_code") @db.VarChar(50)
  department   String?   @db.VarChar(150)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User                 @relation(fields: [userId], references: [id])
  groups        Group[]
  topicProgress GroupTopicProgress[]

  @@map("teachers")
}

// ─────────────────────────────────────────────
// 4. ROLES
// ─────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userRoles UserRole[]

  @@map("roles")
}

// ─────────────────────────────────────────────
// 5. USER_ROLES — M:N bridge
// ─────────────────────────────────────────────

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────
// 6. CAREERS
// ─────────────────────────────────────────────

model Career {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(200)
  code           String    @unique @db.VarChar(20)
  totalSemesters Int       @map("total_semesters") @db.SmallInt
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  students              Student[]
  careerSubjects        CareerSubject[]
  certifications        Certification[]
  certificationCriteria CertificationCriteria[]

  @@map("careers")
}

// ─────────────────────────────────────────────
// 7. SUBJECTS
// ─────────────────────────────────────────────

model Subject {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(200)
  code          String    @unique @db.VarChar(20)
  credits       Int       @db.SmallInt
  tuitionAmount Decimal?  @map("tuition_amount") @db.Decimal(10, 2)
  isActive      Boolean   @default(true) @map("is_active")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  careerSubjects CareerSubject[]
  groups         Group[]
  prerequisites  SubjectPrerequisite[] @relation("SubjectPrereqs")
  isPrereqOf     SubjectPrerequisite[] @relation("PrereqOf")
  syllabusTopics SyllabusTopic[]

  @@map("subjects")
}

// ─────────────────────────────────────────────
// 8. SUBJECT_PREREQUISITES — Self-referencing M:N
// ─────────────────────────────────────────────

model SubjectPrerequisite {
  id             String @id @default(uuid()) @db.Uuid
  subjectId      String @map("subject_id") @db.Uuid
  prerequisiteId String @map("prerequisite_id") @db.Uuid

  subject      Subject @relation("SubjectPrereqs", fields: [subjectId], references: [id])
  prerequisite Subject @relation("PrereqOf", fields: [prerequisiteId], references: [id])

  @@unique([subjectId, prerequisiteId])
  @@map("subject_prerequisites")
}

// ─────────────────────────────────────────────
// 9. CAREER_SUBJECTS — M:N bridge
// ─────────────────────────────────────────────

model CareerSubject {
  id             String  @id @default(uuid()) @db.Uuid
  careerId       String  @map("career_id") @db.Uuid
  subjectId      String  @map("subject_id") @db.Uuid
  semesterNumber Int     @map("semester_number") @db.SmallInt
  isMandatory    Boolean @default(true) @map("is_mandatory")

  career  Career  @relation(fields: [careerId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([careerId, subjectId])
  @@map("career_subjects")
}

// ─────────────────────────────────────────────
// 10. ACADEMIC_PERIODS
// ─────────────────────────────────────────────

model AcademicPeriod {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(50)
  startDate      DateTime     @map("start_date") @db.Date
  endDate        DateTime     @map("end_date") @db.Date
  enrollmentOpen Boolean      @default(false) @map("enrollment_open")
  isActive       Boolean      @default(true) @map("is_active")
  status         PeriodStatus @default(OPEN)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  groups          Group[]
  enrollments     Enrollment[]
  academicRecords AcademicRecord[]
  studentFees     StudentFee[]
  calendarEvents  CalendarEvent[]

  @@map("academic_periods")
}

// ─────────────────────────────────────────────
// 11. CLASSROOMS
// ─────────────────────────────────────────────

model Classroom {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(50)
  building  String?   @db.VarChar(100)
  capacity  Int       @db.SmallInt
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  groupClassrooms GroupClassroom[]

  @@map("classrooms")
}

// ─────────────────────────────────────────────
// 12. GROUPS
// ─────────────────────────────────────────────

model Group {
  id               String            @id @default(uuid()) @db.Uuid
  subjectId        String            @map("subject_id") @db.Uuid
  academicPeriodId String            @map("academic_period_id") @db.Uuid
  teacherId        String            @map("teacher_id") @db.Uuid
  groupCode        String            @map("group_code") @db.VarChar(20)
  deliveryMode     GroupDeliveryMode @default(ON_SITE) @map("delivery_mode")
  maxStudents      Int               @map("max_students") @db.SmallInt
  currentStudents  Int               @default(0) @map("current_students") @db.SmallInt
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  subject            Subject              @relation(fields: [subjectId], references: [id])
  academicPeriod     AcademicPeriod       @relation(fields: [academicPeriodId], references: [id])
  teacher            Teacher              @relation(fields: [teacherId], references: [id])
  groupClassrooms    GroupClassroom[]
  enrollmentSubjects EnrollmentSubject[]
  evaluations        Evaluation[]
  academicRecords    AcademicRecord[]
  topics             Topic[]
  topicProgress      GroupTopicProgress[]

  @@unique([subjectId, academicPeriodId, groupCode])
  @@map("groups")
}

// ─────────────────────────────────────────────
// 13. GROUP_CLASSROOMS — M:N with schedule
// ─────────────────────────────────────────────

model GroupClassroom {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  classroomId String   @map("classroom_id") @db.Uuid
  dayOfWeek   Int      @map("day_of_week") @db.SmallInt
  startTime   DateTime @map("start_time") @db.Time(6)
  endTime     DateTime @map("end_time") @db.Time(6)

  group     Group     @relation(fields: [groupId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])

  @@unique([classroomId, dayOfWeek, startTime, endTime])
  @@map("group_classrooms")
}

// ─────────────────────────────────────────────
// 14. ENROLLMENTS
// ─────────────────────────────────────────────

model Enrollment {
  id               String           @id @default(uuid()) @db.Uuid
  studentId        String           @map("student_id") @db.Uuid
  academicPeriodId String           @map("academic_period_id") @db.Uuid
  status           EnrollmentStatus @default(ACTIVE)
  enrolledAt       DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  student            Student             @relation(fields: [studentId], references: [id])
  academicPeriod     AcademicPeriod      @relation(fields: [academicPeriodId], references: [id])
  enrollmentSubjects EnrollmentSubject[]

  @@unique([studentId, academicPeriodId])
  @@map("enrollments")
}

// ─────────────────────────────────────────────
// 15. ENROLLMENT_SUBJECTS — M:N bridge
// ─────────────────────────────────────────────

model EnrollmentSubject {
  id           String                  @id @default(uuid()) @db.Uuid
  enrollmentId String                  @map("enrollment_id") @db.Uuid
  groupId      String                  @map("group_id") @db.Uuid
  status       EnrollmentSubjectStatus @default(ENROLLED)
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  group      Group      @relation(fields: [groupId], references: [id])

  @@unique([enrollmentId, groupId])
  @@map("enrollment_subjects")
}

// ─────────────────────────────────────────────
// 16. EVALUATION_TYPES
// ─────────────────────────────────────────────

model EvaluationType {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  evaluations Evaluation[]

  @@map("evaluation_types")
}

// ─────────────────────────────────────────────
// 17. EVALUATIONS
// ─────────────────────────────────────────────

model Evaluation {
  id               String    @id @default(uuid()) @db.Uuid
  groupId          String    @map("group_id") @db.Uuid
  evaluationTypeId String    @map("evaluation_type_id") @db.Uuid
  name             String    @db.VarChar(200)
  weight           Decimal   @db.Decimal(5, 2)
  maxScore         Decimal   @default(100) @map("max_score") @db.Decimal(5, 2)
  dueDate          DateTime? @map("due_date") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  group          Group               @relation(fields: [groupId], references: [id])
  evaluationType EvaluationType      @relation(fields: [evaluationTypeId], references: [id])
  grades         Grade[]
  submissions    StudentSubmission[]

  @@map("evaluations")
}

// ─────────────────────────────────────────────
// 17b. STUDENT_SUBMISSIONS
// ─────────────────────────────────────────────

model StudentSubmission {
  id           String          @id @default(uuid()) @db.Uuid
  studentId    String          @map("student_id") @db.Uuid
  evaluationId String          @map("evaluation_id") @db.Uuid
  title        String          @db.VarChar(255)
  type         ContentItemType
  content      String          @db.Text // URL/text/file URL
  fileKey      String?         @map("file_key") @db.VarChar(500) // storage key for deletion
  fileName     String?         @map("file_name") @db.VarChar(255)
  fileSize     Int?            @map("file_size")
  fileMimeType String?         @map("file_mime_type") @db.VarChar(100)
  submittedAt  DateTime        @default(now()) @map("submitted_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  student    Student    @relation(fields: [studentId], references: [id])
  evaluation Evaluation @relation(fields: [evaluationId], references: [id])

  @@unique([studentId, evaluationId])
  @@map("student_submissions")
}

// ─────────────────────────────────────────────
// 18. GRADES
// ─────────────────────────────────────────────

model Grade {
  id           String   @id @default(uuid()) @db.Uuid
  evaluationId String   @map("evaluation_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  score        Decimal  @db.Decimal(5, 2)
  gradedBy     String   @map("graded_by") @db.Uuid
  gradedAt     DateTime @default(now()) @map("graded_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  evaluation Evaluation @relation(fields: [evaluationId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  teacher    User       @relation("GradedBy", fields: [gradedBy], references: [id])

  @@unique([evaluationId, studentId])
  @@map("grades")
}

// ─────────────────────────────────────────────
// 19. ACADEMIC_RECORDS — Trigger-generated
// ─────────────────────────────────────────────

model AcademicRecord {
  id               String   @id @default(uuid()) @db.Uuid
  studentId        String   @map("student_id") @db.Uuid
  groupId          String   @map("group_id") @db.Uuid
  academicPeriodId String   @map("academic_period_id") @db.Uuid
  finalGrade       Decimal  @map("final_grade") @db.Decimal(5, 2)
  passed           Boolean
  attemptNumber    Int      @default(1) @map("attempt_number") @db.SmallInt
  generatedAt      DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)

  student        Student        @relation(fields: [studentId], references: [id])
  group          Group          @relation(fields: [groupId], references: [id])
  academicPeriod AcademicPeriod @relation(fields: [academicPeriodId], references: [id])

  @@unique([studentId, groupId])
  @@map("academic_records")
}

// ─────────────────────────────────────────────
// 20. CERTIFICATION_CRITERIA
// ─────────────────────────────────────────────

model CertificationCriteria {
  id                  String            @id @default(uuid()) @db.Uuid
  certificationType   CertificationType @map("certification_type")
  careerId            String?           @map("career_id") @db.Uuid
  minGrade            Decimal           @default(60.00) @map("min_grade") @db.Decimal(5, 2)
  validityMonths      Int               @map("validity_months") @db.SmallInt
  minCredits          Int?              @map("min_credits") @db.SmallInt
  requireAllMandatory Boolean           @default(false) @map("require_all_mandatory")
  description         String?           @db.VarChar(255)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  career Career? @relation(fields: [careerId], references: [id])

  @@unique([certificationType, careerId])
  @@map("certification_criteria")
}

// ─────────────────────────────────────────────
// 21. CERTIFICATIONS
// ─────────────────────────────────────────────

model Certification {
  id                String              @id @default(uuid()) @db.Uuid
  studentId         String              @map("student_id") @db.Uuid
  careerId          String?             @map("career_id") @db.Uuid
  certificationType CertificationType   @map("certification_type")
  status            CertificationStatus @default(ACTIVE)
  verificationCode  String              @unique @map("verification_code") @db.VarChar(100)
  documentHash      String              @map("document_hash") @db.VarChar(64)
  issuedBy          String              @map("issued_by") @db.Uuid
  issuedAt          DateTime            @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt         DateTime?           @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime?           @map("revoked_at") @db.Timestamptz(6)
  revokedReason     String?             @map("revoked_reason") @db.VarChar(500)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  student Student @relation(fields: [studentId], references: [id])
  career  Career? @relation(fields: [careerId], references: [id])
  issuer  User    @relation("IssuedBy", fields: [issuedBy], references: [id])

  @@map("certifications")
}

// ─────────────────────────────────────────────
// 22. AUDIT_LOGS — Append-only
// ─────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  entityType  String      @map("entity_type") @db.VarChar(50)
  entityId    String      @map("entity_id") @db.Uuid
  action      AuditAction
  performedBy String?     @map("performed_by") @db.Uuid
  oldValues   Json?       @map("old_values") @db.JsonB
  newValues   Json?       @map("new_values") @db.JsonB
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [performedBy], references: [id])

  @@index([entityType, entityId], name: "idx_audit_entity")
  @@index([createdAt], name: "idx_audit_created_at")
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// 23. TOPICS — Course content sections per group
// ─────────────────────────────────────────────

model Topic {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  sortOrder   Int      @map("sort_order") @db.SmallInt
  weekNumber  Int?     @map("week_number") @db.SmallInt
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  group        Group         @relation(fields: [groupId], references: [id])
  contentItems ContentItem[]

  @@unique([groupId, sortOrder])
  @@map("topics")
}

// ─────────────────────────────────────────────
// 24. CONTENT_ITEMS — Materials within a topic
// ─────────────────────────────────────────────

model ContentItem {
  id        String          @id @default(uuid()) @db.Uuid
  topicId   String          @map("topic_id") @db.Uuid
  title     String          @db.VarChar(200)
  type      ContentItemType
  content   String          @db.Text
  sortOrder Int             @map("sort_order") @db.SmallInt
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, sortOrder])
  @@map("content_items")
}

// ─────────────────────────────────────────────
// 25. SYSTEM_SETTINGS — Single-row config
// ─────────────────────────────────────────────

model SystemSettings {
  id                       String   @id @default(uuid()) @db.Uuid
  passingGrade             Decimal  @default(60) @map("passing_grade") @db.Decimal(5, 2)
  maxSubjectsPerEnrollment Int      @default(7) @map("max_subjects_per_enrollment") @db.SmallInt
  maxEvaluationWeight      Decimal  @default(100) @map("max_evaluation_weight") @db.Decimal(5, 2)
  atRiskThreshold          Int      @default(3) @map("at_risk_threshold") @db.SmallInt
  creditCost               Decimal  @default(0) @map("credit_cost") @db.Decimal(10, 2)
  inscriptionFee         Decimal  @default(5000) @map("inscription_fee") @db.Decimal(10, 2)
  cyclesPerYear            Int      @default(2) @map("cycles_per_year") @db.SmallInt
  maxCreditsPerSubject     Int      @default(24) @map("max_credits_per_subject") @db.SmallInt
  signatureImage1          String?  @map("signature_image_1") @db.Text
  signatureName1           String?  @map("signature_name_1") @db.VarChar(200)
  signatureTitle1          String?  @map("signature_title_1") @db.VarChar(200)
  signatureImage2          String?  @map("signature_image_2") @db.Text
  signatureName2           String?  @map("signature_name_2") @db.VarChar(200)
  signatureTitle2          String?  @map("signature_title_2") @db.VarChar(200)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy                String?  @map("updated_by") @db.Uuid

  updater User? @relation("SettingsUpdatedBy", fields: [updatedBy], references: [id])

  @@map("system_settings")
}

// ─────────────────────────────────────────────
// 26. NOTIFICATIONS — In-app notifications
// ─────────────────────────────────────────────

model Notification {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  title           String           @db.VarChar(200)
  message         String           @db.VarChar(500)
  type            NotificationType
  isRead          Boolean          @default(false) @map("is_read")
  relatedEntity   String?          @map("related_entity") @db.VarChar(50)
  relatedEntityId String?          @map("related_entity_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead], name: "idx_notification_user_read")
  @@index([createdAt], name: "idx_notification_created_at")
  @@map("notifications")
}

// ─────────────────────────────────────────────
// 27. FEE_CONCEPTS — Catalog of fee types
// ─────────────────────────────────────────────

model FeeConcept {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  amount      Decimal  @db.Decimal(10, 2)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentFees StudentFee[]

  @@map("fee_concepts")
}

// ─────────────────────────────────────────────
// 28. STUDENT_FEES — Fees assigned to students
// ─────────────────────────────────────────────

model StudentFee {
  id           String    @id @default(uuid()) @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  feeConceptId String    @map("fee_concept_id") @db.Uuid
  periodId     String    @map("period_id") @db.Uuid
  amount       Decimal   @db.Decimal(10, 2)
  dueDate      DateTime  @map("due_date") @db.Date
  status       FeeStatus @default(PENDING)
  installmentNumber Int?    @map("installment_number") @db.SmallInt
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  student    Student        @relation(fields: [studentId], references: [id])
  feeConcept FeeConcept     @relation(fields: [feeConceptId], references: [id])
  period     AcademicPeriod @relation(fields: [periodId], references: [id])
  payments   Payment[]

  @@map("student_fees")
}

// ─────────────────────────────────────────────
// 29. PAYMENTS — Payment records
// ─────────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  studentFeeId  String        @map("student_fee_id") @db.Uuid
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  referenceCode String        @unique @map("reference_code") @db.VarChar(50)
  paidAt        DateTime      @default(now()) @map("paid_at") @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  studentFee StudentFee @relation(fields: [studentFeeId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// 30. ANNOUNCEMENTS
// ─────────────────────────────────────────────

model Announcement {
  id          String               @id @default(uuid()) @db.Uuid
  authorId    String               @map("author_id") @db.Uuid
  title       String               @db.VarChar(200)
  body        String               @db.Text
  audience    AnnouncementAudience
  targetId    String?              @map("target_id") @db.Uuid
  publishedAt DateTime             @default(now()) @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  author User @relation(fields: [authorId], references: [id])

  @@index([audience, targetId], name: "idx_announcement_audience")
  @@map("announcements")
}

// ─────────────────────────────────────────────
// 31. CALENDAR_EVENTS
// ─────────────────────────────────────────────

model CalendarEvent {
  id          String            @id @default(uuid()) @db.Uuid
  title       String            @db.VarChar(200)
  description String?           @db.VarChar(500)
  eventType   CalendarEventType @map("event_type")
  startDate   DateTime          @map("start_date") @db.Date
  endDate     DateTime          @map("end_date") @db.Date
  periodId    String?           @map("period_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  period AcademicPeriod? @relation(fields: [periodId], references: [id])

  @@map("calendar_events")
}

// ─────────────────────────────────────────────
// 28. DEPARTMENTS — Catalogue of academic departments
// ─────────────────────────────────────────────

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("departments")
}

// ─────────────────────────────────────────────
// 32. SYLLABUS_TOPICS — Subject-level curriculum template
// ─────────────────────────────────────────────

model SyllabusTopic {
  id          String   @id @default(uuid()) @db.Uuid
  subjectId   String   @map("subject_id") @db.Uuid
  sortOrder   Int      @map("sort_order") @db.SmallInt
  title       String   @db.VarChar(200)
  description String?  @db.VarChar(1000)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  subject  Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  progress GroupTopicProgress[]

  @@unique([subjectId, sortOrder])
  @@map("syllabus_topics")
}

// ─────────────────────────────────────────────
// 33. GROUP_TOPIC_PROGRESS — Teacher marks syllabus progress per group
// ─────────────────────────────────────────────

model GroupTopicProgress {
  id         String   @id @default(uuid()) @db.Uuid
  groupId    String   @map("group_id") @db.Uuid
  topicId    String   @map("topic_id") @db.Uuid
  teacherId  String   @map("teacher_id") @db.Uuid
  coveredAt  DateTime @map("covered_at") @db.Date
  weekNumber Int      @map("week_number") @db.SmallInt
  notes      String?  @db.VarChar(1000)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  topic   SyllabusTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  teacher Teacher       @relation(fields: [teacherId], references: [id])

  @@unique([groupId, topicId])
  @@map("group_topic_progress")
}

// ─────────────────────────────────────────────
// 34. ADMISSION_DOCUMENTS — Scanned docs uploaded at registration
// ─────────────────────────────────────────────

model AdmissionDocument {
  id              String                  @id @default(uuid()) @db.Uuid
  studentId       String                  @map("student_id") @db.Uuid
  type            AdmissionDocumentType
  fileKey         String                  @map("file_key") @db.VarChar(500)
  fileName        String                  @map("file_name") @db.VarChar(255)
  fileSize        Int                     @map("file_size")
  fileMimeType    String                  @map("file_mime_type") @db.VarChar(100)
  status          AdmissionDocumentStatus @default(PENDING)
  reviewedBy      String?                 @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?               @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason String?                 @map("rejection_reason") @db.VarChar(500)
  uploadedAt      DateTime                @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  updatedAt       DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("AdmissionDocsReviewed", fields: [reviewedBy], references: [id])

  @@index([studentId], name: "idx_admission_docs_student")
  @@index([status], name: "idx_admission_docs_status")
  @@map("admission_documents")
}
